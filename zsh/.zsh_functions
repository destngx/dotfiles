git() {
  if [[ $# -gt 0 ]]; then
    command git "$@"
  else
    command git status -sb
  fi
}

if [[ -n "$(command -v bun)" ]]; then
  bun() {
    if [[ $# -gt 0 ]]; then
      command bun "$@"
    else
      command bun install
    fi
  }
fi

# Override npm with pnpm
npm() {
  case "$1" in
    install)
      pnpm install "${@:2}"
      ;;
    i)
      pnpm install "${@:2}"
      ;;
    add)
      pnpm add "${@:2}"
      ;;
    uninstall|remove|r)
      pnpm remove "${@:2}"
      ;;
    uninstall-global|remove-global|r-global)
      pnpm remove --global "${@:2}"
      ;;
    run)
      pnpm run "${@:2}"
      ;;
    *)
      # For other commands, use pnpm or warning
      echo "npm $@ → pnpm equivalent may vary"
      command pnpm "$@"
      ;;
  esac
}

# yarn function → uses pnpm
yarn() {
  case "$1" in
    install|i) pnpm install "${@:2}" ;;
    add) pnpm add "${@:2}" ;;
    remove|r|uninstall) pnpm remove "${@:2}" ;;
    run) pnpm run "${@:2}" ;;
    exec|x) pnpm dlx "${@:2}" ;;
    list|ls) pnpm list "${@:2}" ;;
    update|up) pnpm update "${@:2}" ;;
    *) pnpm "$@" ;;
  esac
}

# bun function → uses pnpm
bun() {
  case "$1" in
    install|i) pnpm install "${@:2}" ;;
    add) pnpm add "${@:2}" ;;
    remove|r|uninstall) pnpm remove "${@:2}" ;;
    run) pnpm run "${@:2}" ;;
    exec|x) pnpm dlx "${@:2}" ;;
    list|ls) pnpm list "${@:2}" ;;
    update|up) pnpm update "${@:2}" ;;
    *) pnpm "$@" ;;
  esac
}

perp() {
    search=""
    echo "Perplexity lookup for: $@"
    for term in $@; do
        search="$search%20$term"
    done
    xdg-open "https://www.perplexity.ai/search?s=o&q=$search" &
}

ls-port() {
  echo "User processes:"
  lsof -nP -iTCP -sTCP:LISTEN
  echo "System processes require sudo permission:"

  sudo lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null || {
    echo "Error: Unable to list ports. Make sure you have permission."
    return 1
  }
}
is-port-available() {
  local port="$1"
  
  if [ -z "$port" ]; then
    echo "Usage: is-port-open <port_number>"
    return 1
  fi
  
  local result=$(lsof -nP -i:"$port" 2>/dev/null)
  
  if [ -n "$result" ]; then
    echo "Port $port is in use by:"
    echo "$result" | awk 'NR>1 {print "- " $1 " (PID: " $2 ")"}'
  else
    echo "Port $port is available for use"
  fi
}

lich-am() {
